rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /cms/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "sneyder23081994@gmail.com";
    }
    match /profiles/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
